{
  "$defs": {
    "Ownership": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "const": "bounded",
          "title": "Mode",
          "type": "string"
        },
        "scope": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z0-9][a-z0-9_-]*)+$",
          "title": "Scope",
          "type": "string"
        }
      },
      "required": [
        "scope",
        "mode"
      ],
      "title": "Ownership",
      "type": "object"
    },
    "SecretLifecycle": {
      "enum": [
        "operator-created",
        "generated",
        "stack-output"
      ],
      "title": "SecretLifecycle",
      "type": "string"
    },
    "SecretMetadata": {
      "additionalProperties": false,
      "properties": {
        "consumers": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[a-z0-9][a-z0-9._-]*$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Consumers",
          "type": "array"
        },
        "generation_method": {
          "minLength": 1,
          "title": "Generation Method",
          "type": "string"
        },
        "id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Id"
        },
        "key": {
          "pattern": "^homeserver/.+",
          "title": "Key",
          "type": "string"
        },
        "lifecycle": {
          "$ref": "#/$defs/SecretLifecycle"
        },
        "owner": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z0-9][a-z0-9_-]*)+$",
          "title": "Owner",
          "type": "string"
        },
        "purpose": {
          "minLength": 1,
          "title": "Purpose",
          "type": "string"
        },
        "rotation_runbook": {
          "pattern": "^docs/runbooks/.+\\.md(?:#.+)?$",
          "title": "Rotation Runbook",
          "type": "string"
        }
      },
      "required": [
        "key",
        "id",
        "owner",
        "lifecycle",
        "consumers",
        "generation_method",
        "rotation_runbook",
        "purpose"
      ],
      "title": "SecretMetadata",
      "type": "object"
    },
    "SecretProject": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name",
        "id"
      ],
      "title": "SecretProject",
      "type": "object"
    },
    "SecretRef": {
      "additionalProperties": false,
      "description": "A logical reference only; secret material is deliberately not representable.",
      "properties": {
        "alias": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "title": "Alias",
          "type": "string"
        }
      },
      "required": [
        "alias"
      ],
      "title": "SecretRef",
      "type": "object"
    },
    "SecretTargetBinding": {
      "additionalProperties": false,
      "properties": {
        "secret_ref": {
          "$ref": "#/$defs/SecretRef"
        }
      },
      "required": [
        "secret_ref"
      ],
      "title": "SecretTargetBinding",
      "type": "object"
    }
  },
  "$id": "urn:homeserver-iac:schema:secret-metadata",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "ownership": {
      "$ref": "#/$defs/Ownership"
    },
    "project": {
      "$ref": "#/$defs/SecretProject"
    },
    "schema_version": {
      "const": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "secrets": {
      "minProperties": 1,
      "patternProperties": {
        "^[a-z0-9][a-z0-9._-]*$": {
          "$ref": "#/$defs/SecretMetadata"
        }
      },
      "propertyNames": {
        "maxLength": 128,
        "minLength": 1
      },
      "title": "Secrets",
      "type": "object"
    },
    "targets": {
      "minProperties": 1,
      "patternProperties": {
        "^[a-z0-9][a-z0-9._-]*$": {
          "patternProperties": {
            "^[A-Z][A-Za-z0-9_]*$": {
              "$ref": "#/$defs/SecretTargetBinding"
            }
          },
          "type": "object"
        }
      },
      "propertyNames": {
        "maxLength": 128,
        "minLength": 1
      },
      "title": "Targets",
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "ownership",
    "project",
    "secrets",
    "targets"
  ],
  "title": "SecretMetadataDesiredState",
  "type": "object"
}
