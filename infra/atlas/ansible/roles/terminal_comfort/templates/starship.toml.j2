# Managed by Ansible: terminal_comfort

palette = "catppuccin_mocha"
command_timeout = 1500
add_newline = true

format = """
$username\
$hostname\
$directory\
$git_branch\
$git_status\
$docker_context\
$python\
$nodejs\
$rust\
$cmd_duration\
$line_break\
$character\
"""

[username]
show_always = true
style_user = "mauve"
style_root = "red"
format = "[$user]($style)@"

[hostname]
ssh_only = false
style = "sky"
format = "[$hostname]($style) "

[directory]
style = "lavender"
format = "[$path]($style)[$read_only]($read_only_style) "
read_only = " 󰌾"
read_only_style = "subtext1"
truncation_length = 3
truncation_symbol = "…/"

[git_branch]
format = "[$branch]($style) "
style = "overlay1"

[git_status]
format = "[$all_status$ahead_behind]($style) "
style = "overlay2"
conflicted = ":${count} "
ahead = "⇡:${count} "
behind = "⇣:${count} "
diverged = "⇕:${ahead_count}/${behind_count} "
deleted = "✘:${count} "
modified = ":${count} "
stashed = ":${count} "
staged = ":${count} "
renamed = ":${count} "
untracked = ":${count} "

[docker_context]
symbol = " "
format = "[$symbol$context]($style) "
style = "sapphire"

[python]
symbol = " "
format = "[$virtualenv]($style) "
style = "overlay1"
detect_extensions = []
detect_files = []

[nodejs]
symbol = " "
format = "[$symbol($version)]($style) "
style = "green"

[rust]
symbol = "󱘗 "
format = "[$symbol($version)]($style) "
style = "peach"

[cmd_duration]
show_milliseconds = true
format = "[$duration]($style) "
style = "subtext0"
disabled = false

[line_break]
disabled = false

[character]
success_symbol = "[❯](subtext1)"
error_symbol = "[❯](red)"
vimcmd_symbol = "[❮](subtext1)"

[palettes.catppuccin_mocha]
rosewater = "#f5e0dc"
flamingo = "#f2cdcd"
pink = "#f5c2e7"
mauve = "#cba6f7"
red = "#f38ba8"
maroon = "#eba0ac"
peach = "#fab387"
yellow = "#f9e2af"
green = "#a6e3a1"
teal = "#94e2d5"
sky = "#89dceb"
sapphire = "#74c7ec"
blue = "#89b4fa"
lavender = "#b4befe"
text = "#cdd6f4"
subtext1 = "#bac2de"
subtext0 = "#a6adc8"
overlay2 = "#9399b2"
overlay1 = "#7f849c"
overlay0 = "#6c7086"
surface2 = "#585b70"
surface1 = "#45475a"
surface0 = "#313244"
base = "#1e1e2e"
mantle = "#181825"
crust = "#11111b"
