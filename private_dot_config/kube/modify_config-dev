{{- /* chezmoi:modify-template */ -}}
{{- /*
  Preserves current-context from the live kubeconfig while enforcing
  canonical cluster/context/user definitions.
  kubectl writes current-context to the first file in KUBECONFIG,
  so this file in particular sees runtime drift on `kubectl config use-context`.
*/ -}}
{{- $preservedCtx := "dev" -}}
{{- if .chezmoi.stdin -}}
  {{- $cur := fromYaml .chezmoi.stdin -}}
  {{- if $cur -}}
    {{- $v := index $cur "current-context" -}}
    {{- if $v -}}{{- $preservedCtx = $v -}}{{- end -}}
  {{- end -}}
{{- end -}}
apiVersion: v1
kind: Config
clusters:
- cluster:
    certificate-authority-data: 
    server: https://DB0B98C8B093CDAFD657D8203453FF8A.gr7.eu-central-1.eks.amazonaws.com
  name: dev
contexts:
- context:
    cluster: dev
    user: dev
  name: dev
current-context: {{ $preservedCtx }}
users:
- name: dev
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1beta1
      command: aws-login
      args:
      - exec
      - aicc-dev
      - --
      - aws
      - --region
      - eu-central-1
      - eks
      - get-token
      - --cluster-name
      - aicc-cndtag-dev
      - --output
      - json
      interactiveMode: IfAvailable
      provideClusterInfo: false
