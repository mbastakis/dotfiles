{
  "$schema": "https://opencode.ai/config.json",
  // Use OpenAI by default, with optional API-key backed providers available.
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini-fast",
  "autoshare": false,
  "share": "manual",
  "autoupdate": true,
  "enabled_providers": ["openai", "openai-api", "opencode", "wcs"],
  "provider": {
    // Route OpenAI requests to the EU endpoint (required when the OpenAI
    // project is pinned to EU data residency). See:
    // https://platform.openai.com/docs/guides/your-data#data-residency
    "openai": {
      "options": {
        "baseURL": "https://eu.api.openai.com/v1",
      },
      "models": {
        "gpt-5.6-terra": {
          "variants": {
            "max": {
              "reasoningEffort": "max",
              "reasoningSummary": "auto",
              "include": ["reasoning.encrypted_content"],
            },
          },
        },
        "gpt-5.6-sol": {
          "variants": {
            "max": {
              "reasoningEffort": "max",
              "reasoningSummary": "auto",
              "include": ["reasoning.encrypted_content"],
            },
          },
        },
      },
    },
    "openai-api": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI API Key",
      "options": {
        "baseURL": "https://eu.api.openai.com/v1",
        "apiKey": "{env:OPENAI_API_KEY}",
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5 via API key",

          "variants": {
            "none": {
              "reasoningEffort": "none",

              "textVerbosity": "low",

              "reasoningSummary": "auto",
            },

            "low": {
              "reasoningEffort": "low",

              "textVerbosity": "low",

              "reasoningSummary": "auto",
            },

            "medium": {
              "reasoningEffort": "medium",

              "textVerbosity": "low",

              "reasoningSummary": "auto",
            },

            "high": {
              "reasoningEffort": "high",

              "textVerbosity": "low",

              "reasoningSummary": "auto",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",

              "textVerbosity": "low",

              "reasoningSummary": "auto",
            },
          },
        },

        "gpt-5.4": {
          "name": "GPT-5.4 via API key",

          "variants": {
            "low": {
              "reasoningEffort": "low",

              "reasoningSummary": "auto",
            },

            "high": {
              "reasoningEffort": "high",

              "reasoningSummary": "auto",
            },
          },
        },

        "gpt-5.4-mini-fast": {
          "name": "GPT-5.4 Mini Fast via API key",
        },
      },
    },
    "opencode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Zen",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1",
        "apiKey": "{env:OPENCODE_API_KEY}",
      },
      "models": {
        "big-pickle": {
          "name": "Big Pickle",
          "limit": {
            "context": 200000,
            "output": 32000,
          },
        },
        "deepseek-v4-flash-free": {
          "name": "DeepSeek V4 Flash Free",
          "limit": {
            "context": 200000,
            "output": 128000,
          },
          "variants": {
            "off": {
              "thinking": {
                "type": "disabled",
              },
            },
            "high": {
              "reasoningEffort": "high",
            },
            "max": {
              "reasoningEffort": "max",
            },
          },
        },
        "glm-5-free": {
          "name": "GLM-5 Free",
          "limit": {
            "context": 204800,
            "output": 131072,
          },
          "variants": {
            "off": {
              "thinking": {
                "type": "disabled",
              },
            },
            "on": {
              "thinking": {
                "type": "enabled",
              },
            },
          },
        },
        "grok-code": {
          "name": "Grok Code Fast 1",
          "limit": {
            "context": 256000,
            "output": 256000,
          },
        },
        "hy3-preview-free": {
          "name": "Hy3 preview Free",
          "limit": {
            "context": 256000,
            "output": 64000,
          },
        },
        "kimi-k2.5-free": {
          "name": "Kimi K2.5 Free",
          "limit": {
            "context": 262144,
            "output": 262144,
          },
          "variants": {
            "off": {
              "thinking": {
                "type": "disabled",
              },
            },
            "on": {
              "thinking": {
                "type": "enabled",
              },
            },
          },
        },
        "ling-2.6-flash-free": {
          "name": "Ling 2.6 Flash Free",
          "limit": {
            "context": 262100,
            "output": 32800,
          },
        },
        "mimo-v2.5-free": {
          "name": "MiMo V2.5 Free",
          "limit": {
            "context": 200000,
            "output": 32000,
          },
        },
        "minimax-m3-free": {
          "name": "MiniMax-M3 Free",
          "limit": {
            "context": 200000,
            "output": 32000,
          },
          "variants": {
            "off": {
              "thinking": {
                "type": "disabled",
              },
            },
            "on": {
              "thinking": {
                "type": "enabled",
              },
            },
          },
        },
        "nemotron-3-ultra-free": {
          "name": "Nemotron 3 Ultra Free",
          "limit": {
            "context": 1000000,
            "output": 128000,
          },
        },
        "north-mini-code-free": {
          "name": "North Mini Code Free",
          "limit": {
            "context": 256000,
            "output": 64000,
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
            },
            "high": {
              "reasoningEffort": "high",
            },
          },
        },
        "qwen3.6-plus-free": {
          "name": "Qwen3.6 Plus Free",
          "limit": {
            "context": 262144,
            "output": 65536,
          },
          "variants": {
            "off": {
              "thinking": {
                "type": "disabled",
              },
            },
            "on": {
              "thinking": {
                "type": "enabled",
              },
            },
            "max": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 81920,
              },
            },
          },
        },
        "ring-2.6-1t-free": {
          "name": "Ring 2.6 1T Free",
          "limit": {
            "context": 262000,
            "output": 66000,
          },
        },
        "trinity-large-preview-free": {
          "name": "Trinity Large Preview",
          "limit": {
            "context": 131072,
            "output": 131072,
          },
        },
      },
    },
    "wcs": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "WCS",
      "options": {
        "baseURL": "https://ai.whocaressoftware.com/v1",
        "apiKey": "{env:WCS_API_KEY}",
      },
      "models": {
        "gpt": {
          "name": "GPT-5.5 (ChatGPT subscription)",
          "limit": {
            "context": 1050000,
            "output": 128000,
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
            },
            "low": {
              "reasoningEffort": "low",
            },
            "medium": {
              "reasoningEffort": "medium",
            },
            "high": {
              "reasoningEffort": "high",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
            },
          },
        },
        // Disabled until the WCS gateway exposes matching LiteLLM routes.
        // Live /v1/models currently returns only: gpt, deepseek, glm, kimi,
        // qwen, minimax. To enable these aliases, add matching model_name
        // entries on the VM and redeploy LiteLLM, then uncomment them here.
        /*
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (OpenCode Go)",
          "limit": {
            "context": 1000000,
            "output": 384000,
          },
          "variants": {
            "high": {
              "reasoningEffort": "high",
            },
            "max": {
              "reasoningEffort": "max",
            },
          },
        },
        */
        "deepseek": {
          "name": "DeepSeek V4 Pro (OpenCode Go)",
          "limit": {
            "context": 1000000,
            "output": 384000,
          },
          "variants": {
            "high": {
              "reasoningEffort": "high",
            },
            "max": {
              "reasoningEffort": "max",
            },
          },
        },
        /*
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (OpenCode Go)",
          "limit": {
            "context": 1000000,
            "output": 384000,
          },
          "variants": {
            "high": {
              "reasoningEffort": "high",
            },
            "max": {
              "reasoningEffort": "max",
            },
          },
        },
        */
        "glm": {
          "name": "GLM-5.2 (OpenCode Go)",
          "limit": {
            "context": 1000000,
            "output": 131072,
          },
          "variants": {
            "high": {
              "reasoningEffort": "high",
            },
            "max": {
              "reasoningEffort": "max",
            },
          },
        },
        /*
        "glm-5.2": {
          "name": "GLM-5.2 (OpenCode Go)",
          "limit": {
            "context": 1000000,
            "output": 131072,
          },
          "variants": {
            "high": {
              "reasoningEffort": "high",
            },
            "max": {
              "reasoningEffort": "max",
            },
          },
        },
        */
        "kimi": {
          "name": "Kimi K2.7 Code (OpenCode Go)",
          "limit": {
            "context": 262144,
            "output": 262144,
          },
        },
        /*
        "kimi-k2.7-code": {
          "name": "Kimi K2.7 Code (OpenCode Go)",
          "limit": {
            "context": 262144,
            "output": 262144,
          },
        },
        */
        "qwen": {
          "name": "Qwen3.7 Max (OpenCode Go)",
          "limit": {
            "context": 1000000,
            "output": 65536,
          },
          "variants": {
            "off": {
              "thinking": {
                "type": "disabled",
              },
            },
            "on": {
              "thinking": {
                "type": "enabled",
              },
            },
            "max": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 262144,
              },
            },
          },
        },
        /*
        "qwen3.6-plus": {
          "name": "Qwen3.6 Plus (OpenCode Go)",
          "limit": {
            "context": 1000000,
            "output": 65536,
          },
          "variants": {
            "off": {
              "thinking": {
                "type": "disabled",
              },
            },
            "on": {
              "thinking": {
                "type": "enabled",
              },
            },
            "max": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 81920,
              },
            },
          },
        },
        */
        "minimax": {
          "name": "MiniMax-M3 (OpenCode Go)",
          "limit": {
            "context": 1000000,
            "output": 131072,
          },
          "variants": {
            "off": {
              "thinking": {
                "type": "disabled",
              },
            },
            "on": {
              "thinking": {
                "type": "enabled",
              },
            },
          },
        },
        /*
        "minimax-m3": {
          "name": "MiniMax-M3 (OpenCode Go)",
          "limit": {
            "context": 1000000,
            "output": 131072,
          },
          "variants": {
            "off": {
              "thinking": {
                "type": "disabled",
              },
            },
            "on": {
              "thinking": {
                "type": "enabled",
              },
            },
          },
        },
        */
      },
    },
  },
  "agent": {
    "explore": {
      "model": "openai/gpt-5.4-mini-fast",
    },
    "title": {
      "model": "openai/gpt-5.4-mini-fast",
    },
    "summary": {
      "model": "openai/gpt-5.4-mini-fast",
    },
  },
  "permission": {
    "edit": "allow",
    "external_directory": "allow",
    "bash": {
      // IMPORTANT: Broad allow must stay first - last matching rule wins.
      "*": "allow",
      // Destructive filesystem operations.
      "rm*": "ask",
      "rmdir*": "ask",
      "chmod*": "ask",
      "chown*": "ask",
      "sudo": "ask",
      "sudo *": "ask",
      "su": "ask",
      "su *": "ask",
      // Git history/remote modification.
      "git push*": "ask",
      "git * push*": "ask",
      "git reset*": "ask",
      "git * reset*": "ask",
      "git clean*": "ask",
      "git * clean*": "ask",
      "git rm*": "ask",
      "git * rm*": "ask",
      "git rebase*": "ask",
      "git * rebase*": "ask",
      // Kubernetes and infrastructure mutation.
      "kubectl apply*": "ask",
      "kubectl * apply*": "ask",
      "kubectl create*": "ask",
      "kubectl * create*": "ask",
      "kubectl delete*": "ask",
      "kubectl * delete*": "ask",
      "kubectl replace*": "ask",
      "kubectl * replace*": "ask",
      "kubectl patch*": "ask",
      "kubectl * patch*": "ask",
      "kubectl scale*": "ask",
      "kubectl * scale*": "ask",
      "kubectl set*": "ask",
      "kubectl * set*": "ask",
      "kubectl rollout restart*": "ask",
      "kubectl * rollout restart*": "ask",
      "kubectl rollout undo*": "ask",
      "kubectl * rollout undo*": "ask",
      "kubectl drain*": "ask",
      "kubectl * drain*": "ask",
      "kubectl cordon*": "ask",
      "kubectl * cordon*": "ask",
      "kubectl uncordon*": "ask",
      "kubectl * uncordon*": "ask",
      "kubectl taint*": "ask",
      "kubectl * taint*": "ask",
      "kubectl annotate*": "ask",
      "kubectl * annotate*": "ask",
      "kubectl label*": "ask",
      "kubectl * label*": "ask",
      "kubectl edit*": "ask",
      "kubectl * edit*": "ask",
      "aws-login exec * -- kubectl apply*": "ask",
      "aws-login exec * -- kubectl * apply*": "ask",
      "aws-login exec * -- kubectl create*": "ask",
      "aws-login exec * -- kubectl * create*": "ask",
      "aws-login exec * -- kubectl delete*": "ask",
      "aws-login exec * -- kubectl * delete*": "ask",
      "aws-login exec * -- kubectl replace*": "ask",
      "aws-login exec * -- kubectl * replace*": "ask",
      "aws-login exec * -- kubectl patch*": "ask",
      "aws-login exec * -- kubectl * patch*": "ask",
      "aws-login exec * -- kubectl scale*": "ask",
      "aws-login exec * -- kubectl * scale*": "ask",
      "aws-login exec * -- kubectl set*": "ask",
      "aws-login exec * -- kubectl * set*": "ask",
      "aws-login exec * -- kubectl rollout restart*": "ask",
      "aws-login exec * -- kubectl * rollout restart*": "ask",
      "aws-login exec * -- kubectl rollout undo*": "ask",
      "aws-login exec * -- kubectl * rollout undo*": "ask",
      "aws-login exec * -- kubectl drain*": "ask",
      "aws-login exec * -- kubectl * drain*": "ask",
      "aws-login exec * -- kubectl cordon*": "ask",
      "aws-login exec * -- kubectl * cordon*": "ask",
      "aws-login exec * -- kubectl uncordon*": "ask",
      "aws-login exec * -- kubectl * uncordon*": "ask",
      "aws-login exec * -- kubectl taint*": "ask",
      "aws-login exec * -- kubectl * taint*": "ask",
      "aws-login exec * -- kubectl annotate*": "ask",
      "aws-login exec * -- kubectl * annotate*": "ask",
      "aws-login exec * -- kubectl label*": "ask",
      "aws-login exec * -- kubectl * label*": "ask",
      "aws-login exec * -- kubectl edit*": "ask",
      "aws-login exec * -- kubectl * edit*": "ask",
      "helm install*": "ask",
      "helm * install*": "ask",
      "helm upgrade*": "ask",
      "helm * upgrade*": "ask",
      "helm uninstall*": "ask",
      "helm * uninstall*": "ask",
      "helm delete*": "ask",
      "helm * delete*": "ask",
      "helm rollback*": "ask",
      "helm * rollback*": "ask",
      "aws-login exec * -- helm install*": "ask",
      "aws-login exec * -- helm * install*": "ask",
      "aws-login exec * -- helm upgrade*": "ask",
      "aws-login exec * -- helm * upgrade*": "ask",
      "aws-login exec * -- helm uninstall*": "ask",
      "aws-login exec * -- helm * uninstall*": "ask",
      "aws-login exec * -- helm delete*": "ask",
      "aws-login exec * -- helm * delete*": "ask",
      "aws-login exec * -- helm rollback*": "ask",
      "aws-login exec * -- helm * rollback*": "ask",
      "terraform apply*": "ask",
      "terraform * apply*": "ask",
      "terraform destroy*": "ask",
      "terraform * destroy*": "ask",
      "terraform state*": "ask",
      "terraform * state*": "ask",
      "terraform import*": "ask",
      "terraform * import*": "ask",
      "tofu apply*": "ask",
      "tofu * apply*": "ask",
      "tofu destroy*": "ask",
      "tofu * destroy*": "ask",
      "tofu state*": "ask",
      "tofu * state*": "ask",
      "tofu import*": "ask",
      "tofu * import*": "ask",
    },
  },
  "mcp": {
    "pocketsmith": {
      "type": "remote",
      "url": "https://mcp.pocketsmith.com/mcp",
      "enabled": false,
    },
    "telecontext": {
      "type": "remote",
      "url": "https://telecontext.trap.ng.telekom.net/mcp",
      "enabled": false,
    },
  },
  "plugin": [
    "./plugins/tmux-session-state.js",
    "./plugins/clickable-notifier.js",
  ],
  "instructions": [],
}
