{
  "$schema": "https://opencode.ai/config.json",
  // Default to the built-in OpenAI provider, which can use ChatGPT Plus/Pro
  // subscription auth. Use openai-api/gpt-5.4 or openai-api/gpt-5.5 when you
  // want API-key billing.
  "model": "openai/gpt-5.5",
  "autoshare": false,
  "share": "manual",
  "autoupdate": true,
  "provider": {
    // Route OpenAI requests to the EU endpoint (required when the OpenAI
    // project is pinned to EU data residency). See:
    // https://platform.openai.com/docs/guides/your-data#data-residency
    "openai": {
      "options": {
        "baseURL": "https://eu.api.openai.com/v1",
      },
    },
    "openai-api": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI API EU",
      "env": ["OPENAI_API_KEY"],
      "options": {
        "baseURL": "https://eu.api.openai.com/v1",
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4 (API)",
        },
        "gpt-5.5": {
          "name": "GPT-5.5 (API)",
          "cost": {
            // USD per 1M tokens. Keep in sync with models.dev openai/gpt-5.5.
            "input": 5,
            "output": 30,
            "cache_read": 0.5,
            "context_over_200k": {
              "input": 10,
              "output": 45,
              "cache_read": 1,
            },
          },
        },
      },
    },
  },
  "permission": {
    "edit": "allow",
    "external_directory": "allow",
    "bash": {
      // IMPORTANT: Broad allow must stay first - last matching rule wins.
      "*": "allow",
      // Destructive filesystem operations.
      "rm*": "ask",
      "rmdir*": "ask",
      "chmod*": "ask",
      "chown*": "ask",
      "sudo": "ask",
      "sudo *": "ask",
      "su": "ask",
      "su *": "ask",
      // Git history/remote modification.
      "git push*": "ask",
      "git * push*": "ask",
      "git reset*": "ask",
      "git * reset*": "ask",
      "git clean*": "ask",
      "git * clean*": "ask",
      "git rm*": "ask",
      "git * rm*": "ask",
      "git rebase*": "ask",
      "git * rebase*": "ask",
      // Kubernetes and infrastructure mutation.
      "kubectl apply*": "ask",
      "kubectl * apply*": "ask",
      "kubectl create*": "ask",
      "kubectl * create*": "ask",
      "kubectl delete*": "ask",
      "kubectl * delete*": "ask",
      "kubectl replace*": "ask",
      "kubectl * replace*": "ask",
      "kubectl patch*": "ask",
      "kubectl * patch*": "ask",
      "kubectl scale*": "ask",
      "kubectl * scale*": "ask",
      "kubectl set*": "ask",
      "kubectl * set*": "ask",
      "kubectl rollout restart*": "ask",
      "kubectl * rollout restart*": "ask",
      "kubectl rollout undo*": "ask",
      "kubectl * rollout undo*": "ask",
      "kubectl drain*": "ask",
      "kubectl * drain*": "ask",
      "kubectl cordon*": "ask",
      "kubectl * cordon*": "ask",
      "kubectl uncordon*": "ask",
      "kubectl * uncordon*": "ask",
      "kubectl taint*": "ask",
      "kubectl * taint*": "ask",
      "kubectl annotate*": "ask",
      "kubectl * annotate*": "ask",
      "kubectl label*": "ask",
      "kubectl * label*": "ask",
      "kubectl edit*": "ask",
      "kubectl * edit*": "ask",
      "aws-login exec * -- kubectl apply*": "ask",
      "aws-login exec * -- kubectl * apply*": "ask",
      "aws-login exec * -- kubectl create*": "ask",
      "aws-login exec * -- kubectl * create*": "ask",
      "aws-login exec * -- kubectl delete*": "ask",
      "aws-login exec * -- kubectl * delete*": "ask",
      "aws-login exec * -- kubectl replace*": "ask",
      "aws-login exec * -- kubectl * replace*": "ask",
      "aws-login exec * -- kubectl patch*": "ask",
      "aws-login exec * -- kubectl * patch*": "ask",
      "aws-login exec * -- kubectl scale*": "ask",
      "aws-login exec * -- kubectl * scale*": "ask",
      "aws-login exec * -- kubectl set*": "ask",
      "aws-login exec * -- kubectl * set*": "ask",
      "aws-login exec * -- kubectl rollout restart*": "ask",
      "aws-login exec * -- kubectl * rollout restart*": "ask",
      "aws-login exec * -- kubectl rollout undo*": "ask",
      "aws-login exec * -- kubectl * rollout undo*": "ask",
      "aws-login exec * -- kubectl drain*": "ask",
      "aws-login exec * -- kubectl * drain*": "ask",
      "aws-login exec * -- kubectl cordon*": "ask",
      "aws-login exec * -- kubectl * cordon*": "ask",
      "aws-login exec * -- kubectl uncordon*": "ask",
      "aws-login exec * -- kubectl * uncordon*": "ask",
      "aws-login exec * -- kubectl taint*": "ask",
      "aws-login exec * -- kubectl * taint*": "ask",
      "aws-login exec * -- kubectl annotate*": "ask",
      "aws-login exec * -- kubectl * annotate*": "ask",
      "aws-login exec * -- kubectl label*": "ask",
      "aws-login exec * -- kubectl * label*": "ask",
      "aws-login exec * -- kubectl edit*": "ask",
      "aws-login exec * -- kubectl * edit*": "ask",
      "helm install*": "ask",
      "helm * install*": "ask",
      "helm upgrade*": "ask",
      "helm * upgrade*": "ask",
      "helm uninstall*": "ask",
      "helm * uninstall*": "ask",
      "helm delete*": "ask",
      "helm * delete*": "ask",
      "helm rollback*": "ask",
      "helm * rollback*": "ask",
      "aws-login exec * -- helm install*": "ask",
      "aws-login exec * -- helm * install*": "ask",
      "aws-login exec * -- helm upgrade*": "ask",
      "aws-login exec * -- helm * upgrade*": "ask",
      "aws-login exec * -- helm uninstall*": "ask",
      "aws-login exec * -- helm * uninstall*": "ask",
      "aws-login exec * -- helm delete*": "ask",
      "aws-login exec * -- helm * delete*": "ask",
      "aws-login exec * -- helm rollback*": "ask",
      "aws-login exec * -- helm * rollback*": "ask",
      "terraform apply*": "ask",
      "terraform * apply*": "ask",
      "terraform destroy*": "ask",
      "terraform * destroy*": "ask",
      "terraform state*": "ask",
      "terraform * state*": "ask",
      "terraform import*": "ask",
      "terraform * import*": "ask",
      "tofu apply*": "ask",
      "tofu * apply*": "ask",
      "tofu destroy*": "ask",
      "tofu * destroy*": "ask",
      "tofu state*": "ask",
      "tofu * state*": "ask",
      "tofu import*": "ask",
      "tofu * import*": "ask",
    },
  },
  "mcp": {
    "pocketsmith": {
      "type": "remote",
      "url": "https://mcp.pocketsmith.com/mcp",
      "enabled": false,
    },
    "telecontext": {
      "type": "remote",
      "url": "https://telecontext.trap.ng.telekom.net/mcp",
      "enabled": false,
    },
  },
  "plugin": ["@mohak34/opencode-notifier@latest"],
  "instructions": [],
}
