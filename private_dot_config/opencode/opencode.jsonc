{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "autoshare": false,
  "share": "manual",
  "autoupdate": true,
  "permission": {
    "edit": "allow",
    "external_directory": {
      "*": "ask",
      "/tmp/*": "allow",
      "~/.config/opencode/*": "allow",
      "~/.config/opencode/**/*": "allow",
      "/Users/mbastakis/.config/opencode/*": "allow",
      "/Users/mbastakis/.config/opencode/**/*": "allow",
    },
    "bash": {
      // IMPORTANT: This MUST be first - last matching rule wins!
      "*": "ask",
      // === DENY: Dangerous commands ===
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "sudo": "deny",
      "sudo *": "deny",
      "su": "deny",
      "su *": "deny",
      "chmod 777 *": "deny",
      "chown": "deny",
      "chown *": "deny",
      // === ALLOW: Safe text processing ===
      "sort*": "allow",
      "grep*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "wc*": "allow",
      "cut*": "allow",
      "sed*": "allow",
      "awk*": "allow",
      "tr*": "allow",
      "uniq*": "allow",
      "xargs*": "allow",
      "echo*": "allow",
      "eza*": "allow",
      "date*": "allow",
      // === ALLOW: File operations ===
      "mkdir*": "allow",
      "ls*": "allow",
      "du*": "allow",
      "cat*": "allow",
      // === ALLOW: Development tools ===
      "uvx*": "allow",
      "python*": "allow",
      "node*": "allow",
      // === ASK: Package managers ===
      "npm*": "ask",
      "bun*": "ask",
      // === ALLOW: Git read-only ===
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git rev-parse*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "git ls-files*": "allow",
      "git fetch*": "allow",
      // === ALLOW: Git staging ===
      "git add*": "allow",
      "git stash*": "allow",
      "git restore*": "allow",
      // === ALLOW: Chezmoi ===
      "chezmoi diff": "allow",
      "chezmoi status": "allow",
      // === ASK: Git history/remote modification ===
      "git commit*": "ask",
      "git push*": "ask",
      "git checkout*": "ask",
      "git switch*": "ask",
      "git merge*": "ask",
      "git rebase*": "ask",
      "git reset*": "ask",
      "git pull*": "ask",
      "git clean*": "ask",
      "git rm*": "ask",
      // === ASK: File modification ===
      "rm*": "ask",
      "mv*": "ask",
      "cp*": "ask",
      "chmod*": "ask",
    },
  },
  "plugin": ["@mohak34/opencode-notifier@latest"],
  "instructions": [],
}
