{
  "$schema": "https://opencode.ai/config.json",
  // Default to the built-in OpenAI provider, which can use ChatGPT Plus/Pro
  // subscription auth. Use openai-api/gpt-5.4 or openai-api/gpt-5.5 when you
  // want API-key billing.
  "model": "openai/gpt-5.5",
  "autoshare": false,
  "share": "manual",
  "autoupdate": true,
  "provider": {
    // Route OpenAI requests to the EU endpoint (required when the OpenAI
    // project is pinned to EU data residency). See:
    // https://platform.openai.com/docs/guides/your-data#data-residency
    "openai": {
      "options": {
        "baseURL": "https://eu.api.openai.com/v1",
      },
    },
    "openai-api": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI API EU",
      "env": ["OPENAI_API_KEY"],
      "options": {
        "baseURL": "https://eu.api.openai.com/v1",
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4 (API)",
        },
        "gpt-5.5": {
          "name": "GPT-5.5 (API)",
          "cost": {
            // USD per 1M tokens. Keep in sync with models.dev openai/gpt-5.5.
            "input": 5,
            "output": 30,
            "cache_read": 0.5,
            "context_over_200k": {
              "input": 10,
              "output": 45,
              "cache_read": 1,
            },
          },
        },
      },
    },
  },
  "permission": {
    "edit": "allow",
    "external_directory": {
      "*": "ask",
      "/tmp/*": "allow",
      "~/.config/opencode/*": "allow",
      "~/.config/opencode/**/*": "allow",
      "/Users/mbastakis/.config/opencode/*": "allow",
      "/Users/mbastakis/.config/opencode/**/*": "allow",
    },
    "bash": {
      // IMPORTANT: This MUST be first - last matching rule wins!
      "*": "ask",
      // === DENY: Dangerous commands ===
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "sudo": "deny",
      "sudo *": "deny",
      "su": "deny",
      "su *": "deny",
      "chmod 777 *": "deny",
      "chown": "deny",
      "chown *": "deny",
      // === ALLOW: Safe text processing ===
      "sort*": "allow",
      "grep*": "allow",
      "rg*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "wc*": "allow",
      "cut*": "allow",
      "sed*": "allow",
      "awk*": "allow",
      "tr*": "allow",
      "uniq*": "allow",
      "xargs*": "allow",
      "echo*": "allow",
      "eza*": "allow",
      "date*": "allow",
      // === ALLOW: File operations ===
      "mkdir*": "allow",
      "ls*": "allow",
      "du*": "allow",
      "cat*": "allow",
      // === ALLOW: Development tools ===
      "uvx*": "allow",
      "python*": "allow",
      "node*": "allow",
      // === ASK: Package managers ===
      "npm*": "ask",
      "bun*": "ask",
      // === ALLOW: Git read-only ===
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git rev-parse*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "git ls-files*": "allow",
      "git fetch*": "allow",
      // === ALLOW: Git staging ===
      "git add*": "allow",
      "git stash*": "allow",
      "git restore*": "allow",
      // === ALLOW: Chezmoi ===
      "chezmoi diff": "allow",
      "chezmoi status": "allow",
      // === ASK: Git history/remote modification ===
      "git commit*": "ask",
      "git push*": "ask",
      "git checkout*": "ask",
      "git switch*": "ask",
      "git merge*": "ask",
      "git rebase*": "ask",
      "git reset*": "ask",
      "git pull*": "ask",
      "git clean*": "ask",
      "git rm*": "ask",
      // === ASK: File modification ===
      "rm*": "ask",
      "mv*": "ask",
      "cp*": "ask",
      "chmod*": "ask",
    },
  },
  "mcp": {
    "pocketsmith": {
      "type": "remote",
      "url": "https://mcp.pocketsmith.com/mcp",
      "enabled": false,
    },
    "telecontext": {
      "type": "remote",
      "url": "https://telecontext.trap.ng.telekom.net/mcp",
      "enabled": false,
    },
  },
  "plugin": ["@mohak34/opencode-notifier@latest"],
  "instructions": [],
}
