<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mbastakis.opencode-server</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{ printf "%s/bin/opencode-server" .chezmoi.homeDir }}</string>
    </array>

    <key>WorkingDirectory</key>
    <string>{{ .chezmoi.homeDir }}</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>{{ printf "%s/Library/Logs/opencode-server.log" .chezmoi.homeDir }}</string>

    <key>StandardErrorPath</key>
    <string>{{ printf "%s/Library/Logs/opencode-server.error.log" .chezmoi.homeDir }}</string>

    <key>LimitLoadToSessionType</key>
    <array>
        <string>Aqua</string>
    </array>
</dict>
</plist>
