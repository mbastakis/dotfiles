# AICC Platform Workspace (.mrconfig)
#
# Mirrors gitlab.devops.telekom.de/aicc group structure.
# Tracks: fiber (631096), infrastructure/argocd (631103), infrastructure/iac (620010)
#
# Usage:
#   cd workspaces/ma-proj
#   mr checkout          # clone all repos
#   mr -j8 update        # parallel pull all repos
#   mr status            # status across all repos
#   mr -j8 fetch         # parallel fetch all repos
#
# Discover new repos not yet tracked:
#   ./scripts/mr-discover.sh
#

[DEFAULT]
jobs = 8
git_update = git pull --rebase --autostash "$@"

