{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":enablePreCommit"
  ],
  "timezone": "Europe/Athens",
  "schedule": ["before 6am on monday"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "automerge": false,
  "enabledManagers": [
    "ansible-galaxy",
    "custom.regex",
    "dockerfile",
    "github-actions",
    "mise",
    "npm",
    "pep621",
    "pre-commit",
    "terraform"
  ],
  "ignorePaths": [
    "**/.terraform/**",
    "**/.venv/**",
    "**/node_modules/**"
  ],
  "packageRules": [
    {
      "description": "Require approval for major upgrades",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Use the OpenTofu registry for providers and modules",
      "matchDatasources": ["terraform-module", "terraform-provider"],
      "registryUrls": ["https://registry.opentofu.org"]
    },
    {
      "description": "Do not interpret OpenTofu compatibility constraints as Terraform releases",
      "matchManagers": ["terraform"],
      "matchDepTypes": ["required_version"],
      "enabled": false
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Group pre-commit hook updates",
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit hooks"
    },
    {
      "description": "Group repository-local tool updates",
      "matchManagers": ["mise"],
      "groupName": "repository tooling"
    },
    {
      "description": "Keep Python aligned with the homeserver project constraint",
      "matchManagers": ["mise"],
      "matchPackageNames": ["python/cpython"],
      "allowedVersions": "<3.14"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update container images stored in Atlas Ansible defaults",
      "managerFilePatterns": [
        "/^infra\\/atlas\\/ansible\\/roles\\/(?:atlas_homeserver|atlas_immich)\\/defaults\\/main\\.yml$/"
      ],
      "matchStrings": [
        "(?:^|\\n)[a-z0-9_]+_image:\\s+(?<depName>[^\\s:@]+(?:/[^\\s:@]+)*):(?<currentValue>[^\\s@]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?",
        "(?:^|\\n)[a-z0-9_]+_image:\\s+>-\\s+(?<depName>[^\\s:@]+(?:/[^\\s:@]+)*):(?<currentValue>[^\\s@]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update the shared Immich container release",
      "managerFilePatterns": [
        "/^infra\\/atlas\\/ansible\\/roles\\/atlas_immich\\/defaults\\/main\\.yml$/"
      ],
      "matchStrings": [
        "atlas_immich_version:\\s+(?<currentValue>[^\\s]+)\\s+atlas_immich_server_image:\\s+(?<depName>[^\\s]+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update the K9s shell pod image",
      "managerFilePatterns": [
        "/^private_dot_config\\/k9s\\/config\\.yaml$/"
      ],
      "matchStrings": [
        "shellPod:\\s+image:\\s+(?<depName>[^\\s:@]+(?:/[^\\s:@]+)*):(?<currentValue>[^\\s@]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update the Colima K3s release",
      "managerFilePatterns": [
        "/^private_dot_local\\/private_share\\/colima\\/default\\/modify_colima\\.yaml$/"
      ],
      "matchStrings": [
        "# This needs to exactly match a k3s version[^\\n]*\\s+# Default:[^\\n]*\\s+version:\\s+(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "k3s-io/k3s",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose"
    }
  ]
}
