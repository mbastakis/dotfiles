apiVersion: v1
kind: Config
clusters:
- cluster:
    certificate-authority-data: 
    server: https://585C93CD93DE3AFE4FB7877D9976036F.gr7.eu-central-1.eks.amazonaws.com
  name: playground
contexts:
- context:
    cluster: playground
    user: playground
  name: playground
current-context: playground
users:
- name: playground
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1beta1
      command: aws
      args:
      - --region
      - eu-central-1
      - eks
      - get-token
      - --cluster-name
      - aicc-playground
      - --output
      - json
      env:
      - name: AWS_PROFILE
        value: playground
      interactiveMode: IfAvailable
      provideClusterInfo: false
