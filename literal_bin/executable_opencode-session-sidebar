#!/usr/bin/env python3
"""Mouse-aware tmux sidebar for live OpenCode sessions."""

from __future__ import annotations

import curses
import os
import subprocess
import time
import unicodedata
from dataclasses import dataclass
from pathlib import Path


PICKER = Path.home() / "bin" / "opencode-session-picker"
MANAGER = Path.home() / "bin" / "tmux-opencode-sidebar"
FOCUS_OPTION = "@opencode_session_sidebar_previous_pane"
CACHE = (
    Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache"))
    / "opencode"
    / "session-sidebar.tsv"
)
REFRESH_SECONDS = 2.0
REFRESH_TIMEOUT_SECONDS = 8.0
ROW_START = 3
STATUS_GLYPHS = {
    "",
    "",
    "",
    "",
    "",
    "󰑓",
    "",
    "",
    "",
    "",
    "",
    "🟠",
    "🟡",
    "🔴",
    "🟢",
    "⚫",
    "⚪",
}
STATUS_ICONS = {
    "working": "",
    "blocked": "",
    "error": "",
    "done": "",
    "unknown": "",
    "exited": "",
    "deleted": "",
}
STATUS_PRIORITY = {
    "blocked": 1,
    "error": 2,
    "working": 3,
    "done": 4,
    "unknown": 5,
    "exited": 6,
    "deleted": 6,
}


@dataclass(frozen=True)
class SessionRow:
    pane_id: str
    window_id: str
    tmux_session_id: str
    tmux_session_name: str
    status: str
    title: str


@dataclass(frozen=True)
class DisplayLine:
    tmux_session_id: str
    tmux_session_name: str
    row_index: int | None = None


@dataclass(frozen=True)
class Palette:
    base: int
    header: int
    muted: int
    selected: int
    status: dict[str, int]
    status_selected: dict[str, int]


def run_tmux(*args: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["tmux", *args],
        capture_output=True,
        check=False,
        text=True,
    )


def mark_sidebar_pane() -> None:
    pane_id = os.environ.get("TMUX_PANE", "")
    if not pane_id:
        return

    run_tmux(
        "set-option",
        "-p",
        "-t",
        pane_id,
        "@opencode_session_sidebar",
        "1",
        ";",
        "set-option",
        "-g",
        "@opencode_session_sidebar_visible",
        "1",
    )


def sidebar_is_visible() -> bool:
    pane_id = os.environ.get("TMUX_PANE", "")
    if not pane_id:
        return True

    result = run_tmux("display-message", "-p", "-t", pane_id, "#{window_id}")
    if result.returncode != 0:
        return False

    window_id = result.stdout.strip()
    clients = run_tmux("list-clients", "-F", "#{window_id}")
    return window_id in clients.stdout.splitlines()


def parse_rows(output: str) -> list[SessionRow]:
    rows: list[SessionRow] = []
    for line in output.splitlines():
        parts = line.split("\t", 7)
        if len(parts) == 7:
            _, _, pane_id, window_id, tmux_session_id, status, display = parts
            tmux_session_name = tmux_session_id
        elif len(parts) == 8:
            (
                _,
                _,
                pane_id,
                window_id,
                tmux_session_id,
                tmux_session_name,
                status,
                display,
            ) = parts
        else:
            continue
        title = display.strip()
        if title and title[0] in STATUS_GLYPHS:
            title = title[1:].lstrip()
        rows.append(
            SessionRow(
                pane_id,
                window_id,
                tmux_session_id,
                tmux_session_name,
                status,
                title,
            )
        )
    return rows


def current_tmux_session_id() -> str:
    pane_id = os.environ.get("TMUX_PANE", "")
    if not pane_id:
        return ""
    return run_tmux(
        "display-message", "-p", "-t", pane_id, "#{session_id}"
    ).stdout.strip()


def focused_app_pane(previous_pane: str) -> str:
    sidebar_pane = os.environ.get("TMUX_PANE", "")
    if not sidebar_pane:
        return previous_pane

    window_id = run_tmux(
        "display-message", "-p", "-t", sidebar_pane, "#{window_id}"
    ).stdout.strip()
    active_pane = run_tmux(
        "display-message", "-p", "-t", window_id, "#{pane_id}"
    ).stdout.strip()
    if active_pane and active_pane != sidebar_pane:
        return active_pane
    if previous_pane:
        return previous_pane

    return run_tmux(
        "show-window-options", "-v", "-t", window_id, FOCUS_OPTION
    ).stdout.strip()


def build_display_lines(rows: list[SessionRow]) -> list[DisplayLine]:
    groups: dict[tuple[str, str], list[int]] = {}
    for index, row in enumerate(rows):
        key = (row.tmux_session_id, row.tmux_session_name)
        groups.setdefault(key, []).append(index)

    lines: list[DisplayLine] = []
    ordered_groups = sorted(
        groups.items(),
        key=lambda item: item[0][1].casefold(),
    )
    for (session_id, session_name), row_indexes in ordered_groups:
        lines.append(DisplayLine(session_id, session_name))
        row_indexes.sort(key=lambda index: STATUS_PRIORITY.get(rows[index].status, 5))
        lines.extend(
            DisplayLine(session_id, session_name, row_index)
            for row_index in row_indexes
        )
    return lines


def display_row_order(lines: list[DisplayLine]) -> list[int]:
    return [line.row_index for line in lines if line.row_index is not None]


def read_cache() -> list[SessionRow]:
    try:
        if time.time() - CACHE.stat().st_mtime > 300:
            return []
        return parse_rows(CACHE.read_text())
    except OSError:
        return []


def write_cache(output: str) -> None:
    temporary = CACHE.with_name(f"{CACHE.name}.{os.getpid()}.tmp")
    try:
        CACHE.parent.mkdir(parents=True, exist_ok=True)
        temporary.write_text(output)
        temporary.replace(CACHE)
    except OSError:
        try:
            temporary.unlink()
        except OSError:
            pass


def start_refresh() -> tuple[subprocess.Popen[str] | None, str]:
    if not PICKER.is_file():
        return None, f"Missing {PICKER}"
    try:
        return (
            subprocess.Popen(
                [str(PICKER), "--print-rows"],
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
            ),
            "",
        )
    except OSError as exc:
        return None, str(exc)


def finish_refresh(process: subprocess.Popen[str]) -> tuple[list[SessionRow], str]:
    output, stderr = process.communicate()
    if process.returncode != 0:
        return [], stderr.strip() or "Session refresh failed"
    write_cache(output)
    return parse_rows(output), ""


def char_width(char: str) -> int:
    if unicodedata.combining(char) or char in {"\ufe0e", "\ufe0f"}:
        return 0
    return 2 if unicodedata.east_asian_width(char) in {"F", "W"} else 1


def clip(text: str, width: int) -> str:
    result: list[str] = []
    used = 0
    for char in text:
        next_width = char_width(char)
        if used + next_width > width:
            break
        result.append(char)
        used += next_width
    return "".join(result)


def ellipsize(text: str, width: int) -> str:
    if sum(char_width(char) for char in text) <= width:
        return text
    return clip(text, max(0, width - 1)) + "…"


def add_text(
    screen: curses.window,
    y: int,
    x: int,
    text: str,
    attr: int = 0,
) -> None:
    height, width = screen.getmaxyx()
    if y < 0 or y >= height or x < 0 or x >= width - 1:
        return
    try:
        screen.addstr(y, x, clip(text, width - x - 1), attr)
    except curses.error:
        pass


def setup_palette(screen: curses.window) -> Palette:
    if not curses.has_colors() or curses.COLORS < 256:
        return Palette(
            base=curses.A_NORMAL,
            header=curses.A_BOLD,
            muted=curses.A_DIM,
            selected=curses.A_BOLD,
            status={},
            status_selected={},
        )

    curses.start_color()
    pairs = {
        1: (189, 234),  # text / base
        2: (183, 234),  # mauve / base
        3: (146, 234),  # subtext / base
        4: (189, 236),  # text / surface
        5: (111, 234),  # blue / base
        6: (216, 234),  # peach / base
        7: (211, 234),  # red / base
        8: (151, 234),  # green / base
        9: (61, 234),  # overlay / base
        10: (111, 236),  # blue / surface
        11: (216, 236),  # peach / surface
        12: (211, 236),  # red / surface
        13: (151, 236),  # green / surface
        14: (61, 236),  # overlay / surface
    }
    for pair, (foreground, background) in pairs.items():
        curses.init_pair(pair, foreground, background)

    screen.bkgd(" ", curses.color_pair(1))
    return Palette(
        base=curses.color_pair(1),
        header=curses.color_pair(2) | curses.A_BOLD,
        muted=curses.color_pair(3),
        selected=curses.color_pair(4),
        status={
            "working": curses.color_pair(5),
            "blocked": curses.color_pair(6),
            "error": curses.color_pair(7),
            "done": curses.color_pair(8),
            "unknown": curses.color_pair(9),
            "deleted": curses.color_pair(9),
            "exited": curses.color_pair(9),
        },
        status_selected={
            "working": curses.color_pair(10),
            "blocked": curses.color_pair(11),
            "error": curses.color_pair(12),
            "done": curses.color_pair(13),
            "unknown": curses.color_pair(14),
            "deleted": curses.color_pair(14),
            "exited": curses.color_pair(14),
        },
    )


def draw(
    screen: curses.window,
    rows: list[SessionRow],
    selected: int,
    offset: int,
    error: str,
    palette: Palette,
    current_session_id: str,
    focused_pane: str,
) -> int:
    screen.erase()
    height, width = screen.getmaxyx()
    add_text(screen, 0, 1, "AGENT SESSIONS", palette.header)
    count = str(len(rows))
    add_text(screen, 0, max(1, width - len(count) - 2), count, palette.muted)
    add_text(screen, 1, 1, "─" * max(0, width - 3), palette.muted)

    lines = build_display_lines(rows)
    visible_rows = max(0, height - ROW_START - 3)
    selected_line = next(
        (
            index
            for index, line in enumerate(lines)
            if line.row_index == selected
        ),
        0,
    )
    if selected_line < offset:
        offset = selected_line
    elif selected_line >= offset + visible_rows:
        offset = selected_line - visible_rows + 1
    offset = max(0, min(offset, max(0, len(lines) - visible_rows)))

    if rows:
        for y, line_index in enumerate(
            range(offset, min(len(lines), offset + visible_rows)), ROW_START
        ):
            line = lines[line_index]
            if line.row_index is None:
                label = f"  {line.tmux_session_name}"
                attr = (
                    palette.header
                    if line.tmux_session_id == current_session_id
                    else palette.muted | curses.A_BOLD
                )
                add_text(screen, y, 0, ellipsize(label, width - 1), attr)
                continue

            row = rows[line.row_index]
            is_selected = line.row_index == selected
            background = palette.selected if is_selected else palette.base
            status_colors = palette.status_selected if is_selected else palette.status
            if is_selected:
                add_text(screen, y, 0, " " * max(0, width - 1), background)
            if row.pane_id == focused_pane:
                add_text(screen, y, 0, "›", palette.header)
            add_text(
                screen,
                y,
                3,
                STATUS_ICONS.get(row.status, ""),
                status_colors.get(row.status, background),
            )
            add_text(screen, y, 5, ellipsize(row.title, width - 6), background)
    else:
        message = error or "No running sessions"
        add_text(screen, ROW_START, 1, message, palette.muted)

    add_text(screen, height - 3, 1, "─" * max(0, width - 3), palette.muted)
    add_text(screen, height - 2, 1, "j/k move · enter open", palette.muted)
    add_text(screen, height - 1, 1, "click open · q/esc close", palette.muted)
    screen.refresh()
    return offset


def active_client(window_id: str) -> str:
    result = run_tmux(
        "list-clients",
        "-F",
        "#{client_activity}\t#{client_name}\t#{window_id}",
    )
    candidates: list[tuple[int, str]] = []
    for line in result.stdout.splitlines():
        parts = line.split("\t", 2)
        if len(parts) != 3 or parts[2] != window_id:
            continue
        try:
            activity = int(parts[0])
        except ValueError:
            activity = 0
        candidates.append((activity, parts[1]))
    return max(candidates, default=(0, ""))[1]


def focus(row: SessionRow) -> None:
    pane_id = os.environ.get("TMUX_PANE", "")
    current_window = ""
    if pane_id:
        current_window = run_tmux(
            "display-message", "-p", "-t", pane_id, "#{window_id}"
        ).stdout.strip()
    client = active_client(current_window)

    run_tmux("select-window", "-t", row.window_id)
    run_tmux("select-pane", "-t", row.pane_id)
    args = ["switch-client"]
    if client:
        args.extend(["-c", client])
    args.extend(["-t", row.tmux_session_id])
    run_tmux(*args)


def hide_all() -> None:
    if MANAGER.is_file():
        run_tmux("run-shell", "-b", f"{MANAGER} hide")


def tui(screen: curses.window) -> None:
    try:
        curses.curs_set(0)
    except curses.error:
        pass
    curses.mouseinterval(0)
    curses.mousemask(curses.ALL_MOUSE_EVENTS | getattr(curses, "REPORT_MOUSE_POSITION", 0))
    screen.keypad(True)
    screen.timeout(250)

    palette = setup_palette(screen)
    rows = read_cache()
    current_session_id = current_tmux_session_id()
    focused_pane = focused_app_pane("")
    selected = next(
        (
            index
            for index, row in enumerate(rows)
            if row.pane_id == focused_pane
        ),
        0,
    )
    offset = 0
    error = "" if rows else "Loading sessions..."
    last_refresh = 0.0
    refresh_started = 0.0
    refresh_process: subprocess.Popen[str] | None = None
    needs_draw = True

    click_mask = (
        getattr(curses, "BUTTON1_RELEASED", 0)
        | getattr(curses, "BUTTON1_CLICKED", 0)
        | getattr(curses, "BUTTON1_DOUBLE_CLICKED", 0)
    )

    offset = draw(
        screen,
        rows,
        selected,
        offset,
        error,
        palette,
        current_session_id,
        focused_pane,
    )
    needs_draw = False

    while True:
        now = time.monotonic()
        refreshed_focused_pane = focused_app_pane(focused_pane)
        if refreshed_focused_pane != focused_pane:
            focused_pane = refreshed_focused_pane
            needs_draw = True
        if refresh_process is not None and refresh_process.poll() is not None:
            selected_pane = rows[selected].pane_id if rows and selected < len(rows) else ""
            refreshed_rows, refresh_error = finish_refresh(refresh_process)
            refresh_process = None
            if refresh_error:
                error = refresh_error
            else:
                rows = refreshed_rows
                current_session_id = current_tmux_session_id()
                error = ""
                if selected_pane:
                    selected = next(
                        (
                            index
                            for index, row in enumerate(rows)
                            if row.pane_id == selected_pane
                        ),
                        min(selected, max(0, len(rows) - 1)),
                    )
                else:
                    selected = min(selected, max(0, len(rows) - 1))
            needs_draw = True
        elif (
            refresh_process is not None
            and now - refresh_started >= REFRESH_TIMEOUT_SECONDS
        ):
            refresh_process.kill()
            refresh_process.communicate()
            refresh_process = None
            error = "Session refresh timed out"
            needs_draw = True

        if (
            refresh_process is None
            and now - last_refresh >= REFRESH_SECONDS
            and sidebar_is_visible()
        ):
            refresh_process, refresh_error = start_refresh()
            refresh_started = now
            last_refresh = now
            if refresh_error:
                error = refresh_error
                needs_draw = True

        if needs_draw:
            offset = draw(
                screen,
                rows,
                selected,
                offset,
                error,
                palette,
                current_session_id,
                focused_pane,
            )
            needs_draw = False

        key = screen.getch()
        if key == -1:
            continue
        if key in (ord("q"), 27):
            if refresh_process is not None:
                refresh_process.terminate()
            hide_all()
            return
        if key in (curses.KEY_UP, ord("k")) and rows:
            row_order = display_row_order(build_display_lines(rows))
            position = row_order.index(selected)
            selected = row_order[(position - 1) % len(row_order)]
            needs_draw = True
        elif key in (curses.KEY_DOWN, ord("j")) and rows:
            row_order = display_row_order(build_display_lines(rows))
            position = row_order.index(selected)
            selected = row_order[(position + 1) % len(row_order)]
            needs_draw = True
        elif key in (curses.KEY_ENTER, 10, 13) and rows:
            focus(rows[selected])
            needs_draw = True
        elif key == ord("r"):
            last_refresh = 0.0
        elif key == curses.KEY_RESIZE:
            needs_draw = True
        elif key == curses.KEY_MOUSE:
            try:
                _, _, mouse_y, _, button_state = curses.getmouse()
            except curses.error:
                continue
            lines = build_display_lines(rows)
            line_index = offset + mouse_y - ROW_START
            if (
                0 <= line_index < len(lines)
                and lines[line_index].row_index is not None
            ):
                selected = lines[line_index].row_index
                needs_draw = True
                if button_state & click_mask:
                    focus(rows[selected])


def main() -> None:
    mark_sidebar_pane()
    curses.wrapper(tui)


if __name__ == "__main__":
    main()
