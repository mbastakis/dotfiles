#!/bin/bash
set -euo pipefail

NATIVE_SAVE="${TMUX_RESURRECT_NATIVE_SAVE:-$HOME/.config/tmux/plugins/tmux-resurrect/scripts/save.sh}"
PANE_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/opencode/tmux-session-state/panes"
SESSION_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/opencode/tmux-panes"
SAVE_LOCK="opencode-resurrect-save"
SIDEBAR_PANE_OPTION="@opencode_session_sidebar"
SIDEBAR_LAYOUT_OPTION="@opencode_session_sidebar_layout"
SIDEBAR_TOPOLOGY_OPTION="@opencode_session_sidebar_application_panes"
SIDEBAR_FOCUS_OPTION="@opencode_session_sidebar_previous_pane"
SYNC_MANIFEST="${TMUX_SAVE_SYNC_MANIFEST:-${TMPDIR:-/tmp}/tmux-opencode-save.$$.sessions}"
SIDEBAR_INVENTORY="${TMPDIR:-/tmp}/tmux-opencode-save.$$.panes"
SIDEBAR_MANIFEST="${TMUX_SAVE_SIDEBAR_MANIFEST:-${TMPDIR:-/tmp}/tmux-opencode-save.$$.sidebars}"
ARCHIVE_WORK_DIR=""

cleanup() {
    set +e
    rm -f "$SYNC_MANIFEST" "$SIDEBAR_INVENTORY" "$SIDEBAR_MANIFEST"
    if [[ -n "$ARCHIVE_WORK_DIR" ]]; then
        rm -rf "$ARCHIVE_WORK_DIR"
    fi
    tmux wait-for -U "$SAVE_LOCK"
}

build_sidebar_manifest() {
    local pane_base_index

    pane_base_index="$(tmux show-option -gv pane-base-index 2>/dev/null || printf 0)"
    tmux list-panes -a -F $'#{window_id}\t#{session_name}\t#{window_index}\t#{pane_index}\t#{pane_id}\t'"#{${SIDEBAR_PANE_OPTION}}"$'\t#{pane_active}\t'"#{${SIDEBAR_LAYOUT_OPTION}}"$'\t'"#{${SIDEBAR_FOCUS_OPTION}}"$'\t'"#{${SIDEBAR_TOPOLOGY_OPTION}}" > "$SIDEBAR_INVENTORY"
    awk -F '\t' -v OFS='\t' -v base="$pane_base_index" '
        {
            count++
            window_id[count] = $1
            session[count] = $2
            window[count] = $3
            old_index[count] = $4
            pane_id[count] = $5
            marker[count] = $6
            key = $1 SUBSEP $2 SUBSEP $3
            pane_key[count] = key
            layout[key] = $8
            previous[key] = $9
            topology[key] = $10
            if ($6 == "1") {
                sidebars[key]++
            } else {
                apps[key]++
                app[key SUBSEP $5] = 1
                if (!(key in first_app)) first_app[key] = $5
                if ($7 == "1") active_app[key] = $5
            }
        }
        END {
            for (i = 1; i <= count; i++) {
                key = pane_key[i]
                if (sidebars[key] != 1 || apps[key] < 1) continue
                topology_matches = (layout[key] != "" && topology[key] != "")
                saved_count = split(topology[key], saved_ids, ",")
                if (saved_count != apps[key]) topology_matches = 0
                for (j = 1; j <= count && topology_matches; j++) {
                    if (pane_key[j] == key && marker[j] != "1" && "," topology[key] "," !~ "," pane_id[j] ",") {
                        topology_matches = 0
                    }
                }
                canonical_layout = topology_matches ? layout[key] : "tiled"
                selected = active_app[key]
                if (selected == "" && app[key SUBSEP previous[key]]) selected = previous[key]
                if (selected == "") selected = first_app[key]
                if (marker[i] == "1") {
                    new_index = ""
                } else {
                    new_index = base + ranks[key]++
                }
                print session[i], window[i], old_index[i], new_index, marker[i], (pane_id[i] == selected ? 1 : 0), canonical_layout
            }
        }
    ' "$SIDEBAR_INVENTORY" > "$SIDEBAR_MANIFEST"
}

saved_pane_index() {
    local session="$1" window="$2" pane="$3"
    local map_session map_window old_index new_index marker _selected _layout

    while IFS=$'\t' read -r map_session map_window old_index new_index marker _selected _layout; do
        if [[ "$map_session" == "$session" && "$map_window" == "$window" && "$old_index" == "$pane" && "$marker" != "1" ]]; then
            printf '%s' "$new_index"
            return 0
        fi
    done < "$SIDEBAR_MANIFEST"
    printf '%s' "$pane"
}

normalize_saved_snapshot() {
    local save_file="${1:-}" tmp

    if [[ -z "$save_file" || ! -f "$save_file" ]]; then
        echo "Error: tmux-resurrect candidate snapshot is missing" >&2
        return 1
    fi
    if [[ ! -f "$SIDEBAR_MANIFEST" || ! -f "$SYNC_MANIFEST" ]]; then
        echo "Error: tmux save normalization manifests are missing" >&2
        return 1
    fi
    tmp="${save_file}.$$.tmp"
    if ! awk -F '\t' -v OFS='\t' \
        -v sidebar_manifest="$SIDEBAR_MANIFEST" \
        -v sync_manifest="$SYNC_MANIFEST" \
        -v home="$HOME" '
        FILENAME == sidebar_manifest {
            pane_key = $1 SUBSEP $2 SUBSEP $3
            window_key = $1 SUBSEP $2
            new_index[pane_key] = $4
            marker[pane_key] = $5
            selected[pane_key] = $6
            layout[window_key] = $7
            next
        }
        FILENAME == sync_manifest {
            session_id[$1] = $2
            next
        }
        $1 == "pane" {
            pane_key = $2 SUBSEP $3 SUBSEP $6
            if (pane_key in marker) {
                if (marker[pane_key] == "1") next
                $6 = new_index[pane_key]
                $9 = selected[pane_key]
            }
            if ($11 ~ /opencode-launch/) {
                session_key = $2 "/" $3 "/" $6
                if (session_key in session_id) {
                    $11 = ":/bin/bash " home "/bin/opencode-restore-session " session_id[session_key]
                } else {
                    $11 = ":/bin/bash " home "/bin/opencode-launch --continue"
                }
            }
            print
            next
        }
        $1 == "window" {
            window_key = $2 SUBSEP $3
            if (window_key in layout) $7 = layout[window_key]
        }
        { print }
    ' "$SIDEBAR_MANIFEST" "$SYNC_MANIFEST" "$save_file" > "$tmp"; then
        rm -f "$tmp"
        return 1
    fi
    if [[ ! -s "$tmp" ]]; then
        rm -f "$tmp"
        echo "Error: tmux save normalization produced an empty snapshot" >&2
        return 1
    fi
    mv "$tmp" "$save_file"
}

filter_saved_pane_contents() {
    local resurrect_dir archive tmp_archive content_dir
    local session window old_index new_index marker _selected _layout old_file staged_file

    [[ -s "$SIDEBAR_MANIFEST" ]] || return 0
    resurrect_dir="$(tmux show-option -gqv '@resurrect-dir' 2>/dev/null || true)"
    resurrect_dir="${resurrect_dir:-${XDG_DATA_HOME:-$HOME/.local/share}/tmux/resurrect}"
    resurrect_dir="${resurrect_dir/#\~/$HOME}"
    archive="$resurrect_dir/pane_contents.tar.gz"
    [[ -f "$archive" ]] || return 0

    ARCHIVE_WORK_DIR="$(mktemp -d "${TMPDIR:-/tmp}/tmux-opencode-save.$$.XXXXXX")"
    if ! tar -xzf "$archive" -C "$ARCHIVE_WORK_DIR"; then
        return 0
    fi
    content_dir="$ARCHIVE_WORK_DIR/pane_contents"
    [[ -d "$content_dir" ]] || return 0

    while IFS=$'\t' read -r session window old_index new_index marker _selected _layout; do
        old_file="$content_dir/pane-${session}:${window}.${old_index}"
        [[ -f "$old_file" ]] || continue
        if [[ "$marker" == "1" ]]; then
            rm -f "$old_file"
        elif [[ "$old_index" != "$new_index" ]]; then
            mv "$old_file" "${old_file}.sidebar-remap"
        fi
    done < "$SIDEBAR_MANIFEST"

    while IFS=$'\t' read -r session window old_index new_index marker _selected _layout; do
        [[ "$marker" != "1" && "$old_index" != "$new_index" ]] || continue
        old_file="$content_dir/pane-${session}:${window}.${old_index}"
        staged_file="${old_file}.sidebar-remap"
        [[ -f "$staged_file" ]] && mv "$staged_file" "$content_dir/pane-${session}:${window}.${new_index}"
    done < "$SIDEBAR_MANIFEST"

    tmp_archive="${archive}.$$.tmp"
    tar -czf "$tmp_archive" -C "$ARCHIVE_WORK_DIR" ./pane_contents
    mv "$tmp_archive" "$archive"
}

sync_live_sessions() {
    local file pane_id process_id session_id directory key target pane_tty process_tty pane_directory
    local pane_location tmux_session window_index pane_index saved_index

    : > "$SYNC_MANIFEST"
    [[ -d "$PANE_STATE_DIR" ]] || return 0
    shopt -s nullglob
    for file in "$PANE_STATE_DIR"/*.json; do
        pane_id="$(jq -r '.tmuxPane // empty' "$file" 2>/dev/null || true)"
        process_id="$(jq -r '.processID // empty' "$file" 2>/dev/null || true)"
        session_id="$(jq -r '.sessionID // empty' "$file" 2>/dev/null || true)"
        directory="$(jq -r '.directory // empty' "$file" 2>/dev/null || true)"
        [[ -n "$pane_id" && "$process_id" =~ ^[0-9]+$ && -n "$session_id" && -n "$directory" ]] || continue
        kill -0 "$process_id" 2>/dev/null || continue

        target="$(tmux display-message -p -t "$pane_id" '#{pane_id}' 2>/dev/null || true)"
        [[ "$target" == "$pane_id" ]] || continue
        pane_tty="$(tmux display-message -p -t "$pane_id" '#{pane_tty}' 2>/dev/null || true)"
        process_tty="$(ps -p "$process_id" -o tty= 2>/dev/null | tr -d '[:space:]')"
        [[ -n "$pane_tty" && "$pane_tty" == "/dev/$process_tty" ]] || continue
        pane_directory="$(tmux display-message -p -t "$pane_id" '#{pane_current_path}' 2>/dev/null || true)"
        [[ "$pane_directory" == "$directory" ]] || continue
        pane_location="$(tmux display-message -p -t "$pane_id" $'#{session_name}\t#{window_index}\t#{pane_index}' 2>/dev/null || true)"
        IFS=$'\t' read -r tmux_session window_index pane_index <<< "$pane_location"
        [[ -n "$tmux_session" && -n "$window_index" && -n "$pane_index" ]] || continue
        saved_index="$(saved_pane_index "$tmux_session" "$window_index" "$pane_index")"
        key="$tmux_session/$window_index/$saved_index"

        mkdir -p "$(dirname "$SESSION_STATE_DIR/$key")"
        printf '%s\n' "$session_id" > "$SESSION_STATE_DIR/$key"
        printf '%s\t%s\n' "$key" "$session_id" >> "$SYNC_MANIFEST"
    done
    return 0
}

if [[ "${1:-}" == "--normalize-snapshot" ]]; then
    if [[ $# -ne 2 ]]; then
        echo "Usage: tmux-save --normalize-snapshot SNAPSHOT" >&2
        exit 2
    fi
    normalize_saved_snapshot "$2"
    exit 0
fi

if [[ ! -x "$NATIVE_SAVE" ]]; then
    echo "Error: tmux-resurrect save script not found: $NATIVE_SAVE" >&2
    exit 1
fi

tmux wait-for -L "$SAVE_LOCK"
trap cleanup EXIT
: > "$SYNC_MANIFEST"
build_sidebar_manifest
command -v jq >/dev/null 2>&1 && sync_live_sessions
export TMUX_SAVE_SYNC_MANIFEST="$SYNC_MANIFEST"
export TMUX_SAVE_SIDEBAR_MANIFEST="$SIDEBAR_MANIFEST"
"$NATIVE_SAVE" "$@"
filter_saved_pane_contents
