#!/bin/bash
set -euo pipefail

# ---------------------------------------------------------------------------
# opencode-launch — opencode wrapper with per-pane session tracking.
#
# Behaviour:
#   opencode-launch          → always starts a NEW opencode session  (oc)
#   opencode-launch -c       → resumes this pane's saved session     (occ / resurrect)
#   opencode-launch -s <id>  → passed through as-is
#
# The attached TUI plugin keeps the pane mapping current as sessions change.
# After exit that active ID is persisted so --continue reopens the same session.
#
# State dir: ~/.local/state/opencode/tmux-panes/
# File key:  {tmux_session}/{window}/{pane}  →  opencode session ID
# ---------------------------------------------------------------------------

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/opencode/tmux-panes"
PLUGIN_PANE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/opencode/tmux-session-state/panes"
SERVER_URL="${OPENCODE_SERVER_URL:-}"
SERVER_URL="${SERVER_URL%/}"

# --- helpers ---------------------------------------------------------------

sql_escape() {
    # Escape single quotes for safe SQL string interpolation.
    printf '%s' "$1" | sed "s/'/''/g"
}

safe_name() {
    printf '%s' "$1" | tr -c 'A-Za-z0-9_.%-' '_'
}

pane_key() {
    # Stable key for the current tmux pane: session/window/pane.
    # Uses / as delimiter since it's invalid in tmux session names,
    # avoiding ambiguity (e.g. session "foo_1" vs "foo" window "1").
    # Uses -t "$TMUX_PANE" so we always query THIS pane, not the
    # client's currently active pane.
    if [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]]; then
        tmux display-message -t "$TMUX_PANE" -p '#{session_name}/#{window_index}/#{pane_index}' 2>/dev/null || true
    fi
}

session_exists() {
    local sid="$1"
    local count
    count="$(opencode db \
        "SELECT COUNT(*) as c FROM session WHERE id = '$(sql_escape "$sid")'" \
        --format json 2>/dev/null \
        | sed -n 's/.*"c"[[:space:]]*:[[:space:]]*\([0-9]*\).*/\1/p' \
        | head -1)" || true
    [[ "${count:-0}" -gt 0 ]]
}

load_session_id() {
    # Return the saved opencode session ID for this pane, if it still exists.
    local key="$1"
    [[ -z "$key" ]] && return 0
    local file="$STATE_DIR/$key"   # e.g. .../tmux-panes/main/1/1
    if [[ -f "$file" ]]; then
        local sid
        sid="$(cat "$file")"
        if [[ -n "${sid:-}" ]] && session_exists "$sid"; then
            printf '%s' "$sid"
        else
            rm -f "$file"   # stale — clean up
        fi
    fi
}

save_session_id() {
    # Persist the session ID for this pane.
    # $1 = pane key, $2 = known session ID (optional).
    local key="$1" known_id="${2:-}"
    [[ -z "$key" ]] && return 0

    local sid="$known_id"

    if [[ -z "$sid" ]]; then
        # Find the most recently active top-level session in $PWD.
        # parent_id IS NULL excludes subagent sessions.
        # ORDER BY time_updated DESC picks the session we were just using
        # (its time_updated was bumped during our interaction).
        # pwd -P resolves symlinks (e.g. /tmp → /private/tmp on macOS)
        # to match the path opencode stores in its DB.
        sid="$(opencode db \
            "SELECT id FROM session WHERE directory = '$(sql_escape "$(pwd -P)")' AND parent_id IS NULL ORDER BY time_updated DESC LIMIT 1" \
            --format json 2>/dev/null \
            | sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' \
            | head -1)" || true
    fi

    if [[ -n "${sid:-}" ]]; then
        mkdir -p "$(dirname "$STATE_DIR/$key")"
        printf '%s\n' "$sid" > "$STATE_DIR/$key"
    fi
}

save_pane_state() {
    local session_id="$1"
    local pane_id="${TMUX_PANE:-}"
    [[ -z "$session_id" || -z "$pane_id" ]] && return 0

    local file
    file="$PLUGIN_PANE_DIR/$(safe_name "$pane_id").json"
    local tmp="${file}.$$.tmp"
    local updated
    updated="$(($(date +%s) * 1000))"

    mkdir -p "$PLUGIN_PANE_DIR"
    jq -n \
        --arg sessionID "$session_id" \
        --arg tmuxPane "$pane_id" \
        --arg directory "$(pwd -P)" \
        --argjson processID "$$" \
        --argjson lastUpdated "$updated" \
        '{
            version: 1,
            sessionID: $sessionID,
            tmuxPane: $tmuxPane,
            processID: $processID,
            status: "unknown",
            directory: $directory,
            lastUpdated: $lastUpdated
        }' > "$tmp"
    mv "$tmp" "$file"
}

current_pane_session_id() {
    local pane_id="${TMUX_PANE:-}"
    [[ -z "$pane_id" ]] && return 0

    local file
    file="$PLUGIN_PANE_DIR/$(safe_name "$pane_id").json"
    [[ -f "$file" ]] && jq -r '.sessionID // empty' "$file" 2>/dev/null || true
}

remove_pane_state() {
    local pane_id="${TMUX_PANE:-}"
    [[ -z "$pane_id" ]] && return 0

    rm -f "$PLUGIN_PANE_DIR/$(safe_name "$pane_id").json"
}

require_shared_server() {
    if ! command -v curl >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
        echo "Error: curl and jq are required for the shared OpenCode server" >&2
        exit 1
    fi

    if ! curl --fail --silent --show-error --max-time 2 "$SERVER_URL/global/health" >/dev/null; then
        echo "Error: shared OpenCode server is unavailable at $SERVER_URL" >&2
        exit 1
    fi
}

create_session() {
    local response
    response="$(curl --fail --silent --show-error --max-time 10 \
        --request POST \
        --header "x-opencode-directory: $(pwd -P)" \
        --header "Content-Type: application/json" \
        --data '{}' \
        "$SERVER_URL/session")"
    jq -er '.id' <<< "$response"
}

# --- parse args ------------------------------------------------------------

_pane_key="$(pane_key)"

# Detect whether the caller asked to continue (-c/--continue) or specified
# an explicit session (-s/--session).  Everything else is passed through.
want_continue=false
has_explicit_session=false
explicit_session_id=""
expect_session_id=false
for arg in "$@"; do
    if "$expect_session_id"; then
        explicit_session_id="$arg"
        expect_session_id=false
        continue
    fi

    case "$arg" in
        -c|--continue) want_continue=true ;;
        -s|--session)
            has_explicit_session=true
            expect_session_id=true
            ;;
        --session=*)
            has_explicit_session=true
            explicit_session_id="${arg#--session=}"
            ;;
    esac
done

# --- build launch args -----------------------------------------------------

extra_args=()
known_id="$explicit_session_id"

if "$want_continue" && ! "$has_explicit_session" && [[ -n "$_pane_key" ]]; then
    saved_id="$(load_session_id "$_pane_key")"
    if [[ -n "${saved_id:-}" ]]; then
        # Replace the generic --continue with the precise session ID.
        known_id="$saved_id"
        extra_args=(-s "$saved_id")
        # Strip -c/--continue from "$@" since we're replacing it with -s.
        filtered_args=()
        for arg in "$@"; do
            case "$arg" in
                -c|--continue) ;;          # drop
                *)             filtered_args+=("$arg") ;;
            esac
        done
        set -- "${filtered_args[@]+"${filtered_args[@]}"}"
    fi
    # If no saved ID, fall through — opencode's own -c picks the last session.
fi

# --- run opencode ----------------------------------------------------------

rc=0
if [[ -n "$SERVER_URL" ]]; then
    require_shared_server

    if ! "$want_continue" && ! "$has_explicit_session"; then
        known_id="$(create_session)"
        extra_args=(-s "$known_id")
    fi

    if [[ -n "$known_id" ]]; then
        save_session_id "$_pane_key" "$known_id"
        save_pane_state "$known_id"
    fi

    opencode attach "$SERVER_URL" --dir "$(pwd -P)" \
        "${extra_args[@]+"${extra_args[@]}"}" "$@" || rc=$?
else
    opencode "${extra_args[@]+"${extra_args[@]}"}" "$@" || rc=$?
fi

# --- persist session ID ----------------------------------------------------

active_id="$known_id"
if [[ -n "$SERVER_URL" ]]; then
    mapped_id="$(current_pane_session_id)"
    [[ -n "$mapped_id" ]] && active_id="$mapped_id"
fi
save_session_id "$_pane_key" "$active_id"
remove_pane_state

exit "$rc"
