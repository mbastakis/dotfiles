#!/bin/bash
# Keep mail-sync LaunchAgent loaded after config changes.
# hash-plist: {{ include "private_Library/LaunchAgents/com.mbastakis.mail-sync.plist.tmpl" | sha256sum }}
# interval-seconds: {{ mul .mail.defaults.sync_interval_minutes 60 }}

{{- if ne .chezmoi.os "darwin" }}
exit 0
{{- end }}

set -euo pipefail

domain="gui/$(id -u)"
label="com.mbastakis.mail-sync"
plist="$HOME/Library/LaunchAgents/${label}.plist"

if [[ ! -f "$plist" ]]; then
    exit 0
fi

# GUI domain is unavailable in headless/non-login sessions.
if ! launchctl print "$domain" >/dev/null 2>&1; then
    exit 0
fi

launchctl bootout "$domain/$label" >/dev/null 2>&1 || true
launchctl bootstrap "$domain" "$plist"
