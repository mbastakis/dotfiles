#!/bin/bash

{{- if ne .chezmoi.os "darwin" }}
exit 0
{{- end }}

set -euo pipefail

{{- $mailRoot := replace "~" .chezmoi.homeDir .mail.defaults.mail_root }}
{{- $notmuchDatabase := replace "~" .chezmoi.homeDir .mail.defaults.notmuch_database }}
{{- $isyncStateRoot := replace "~" .chezmoi.homeDir .mail.defaults.isync_state_root }}
{{- $logRoot := replace "~" .chezmoi.homeDir .mail.defaults.log_root }}
{{- $automationHookRoot := replace "~" .chezmoi.homeDir .mail.defaults.automation_hook_root }}

echo "Creating mail runtime directories..."

mkdir -p \
    "{{ $mailRoot }}" \
    "{{ $notmuchDatabase }}" \
    "{{ $isyncStateRoot }}" \
    "{{ $logRoot }}" \
    "$HOME/.cache/neomutt" \
    "$HOME/.config/abook" \
    "$HOME/.local/share/abook" \
    "{{ $automationHookRoot }}"

echo "Mail runtime directory setup complete."
